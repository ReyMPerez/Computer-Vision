## Install Required Packages

!pip install -U ultralytics
from ultralytics import YOLOWorld

from IPython.display import Image
import os

## Create Model

# Create a YOLOWorld model
model = YOLOWorld("yolov8s-world.pt")

## Model (General)

# Conduct model validation on the COCO dataset
metrics = model.val(
    data="coco.yaml",
    imgsz=512,
    batch=2,
    cache=False,
    plots=True
)

precision = metrics.box.p.mean()
recall = metrics.box.r.mean()
f1 = 2 * (precision * recall) / (precision + recall)

print(f"Precision: {precision:.4f}")
print(f"Recall: {recall:.4f}")
print(f"F1 Score: {f1:.4f}")
print(f"mAP50: {metrics.box.map50:.4f}")
print(f"mAP50-95: {metrics.box.map:.4f}")

f1_path = os.path.join(metrics.save_dir, "BoxF1_curve.png")
if os.path.exists(f1_path):
    display(Image(filename=f1_path))
else:
    print("F1 curve not found. Check contents of:", metrics.save_dir)
    print(os.listdir(metrics.save_dir))

cm_path = os.path.join(metrics.save_dir, "confusion_matrix.png")
if os.path.exists(cm_path):
    display(Image(filename=cm_path))
else:
    print("Confusion matrix not found. Check contents of:", metrics.save_dir)
    print(os.listdir(metrics.save_dir))

## Model (Pre-Training)

homeobjects_classes = [
"bed",
"sofa",
"chair",
"table",
"lamp",
"tv",
"laptop",
"wardrobe",
"window",
"door",
"potted plant",
"photo frame"
]
model.set_classes(homeobjects_classes)

# Model validation on 'lamp' (4) and 'potted plant' (10) before training
metrics_before = model.val(
    data="HomeObjects-3K.yaml",
    imgsz=512,
    batch=4,
    workers=0
)

class4_before = metrics_before.box.maps[4]
class10_before = metrics_before.box.maps[10]

print("BEFORE TRAINING")
print("Class 4 mAP50:", class4_before)
print("Class 10 mAP50:", class10_before)

## Model (Training)

# Train model to detect 'lamp' (4) and 'potted plant' (10)
model.train(
    data="HomeObjects-3K.yaml",
    classes=[4, 10],
    epochs=20,
    imgsz=512,
    batch=4
)

# Load BEST trained weights
best_path = os.path.join(model.trainer.save_dir, "weights", "best.pt")
model = YOLOWorld(best_path)

## Model (Post-Training)

# Model validation on 'lamp' (4) and 'potted plant' (10) after training
metrics_after = model.val(
    data="HomeObjects-3K.yaml",
    imgsz=512,
    batch=4,
    workers=0
)

class4_after = metrics_after.box.maps[4]
class10_after = metrics_after.box.maps[10]

print("\nAFTER TRAINING")
print("Class 4 mAP50:", class4_after)
print("Class 10 mAP50:", class10_after)

## Model (Comparison)

# Show Improvement
print("\nGAIN")
print("Class 4 Gain:", class4_after - class4_before)
print("Class 10 Gain:", class10_after - class10_before)
